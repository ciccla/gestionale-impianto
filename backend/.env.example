# Ambiente
NODE_ENV=staging
FEATURE_SAFE_MODE=true

# Database PostgreSQL
PG_HOST=tuo_host_staging
PG_PORT=5432
PG_DATABASE=nome_db_staging
PG_USER=utente_staging
PG_PASSWORD=password_staging

# Sicurezza sessioni e token
SESSION_SECRET=metti_uno_secret_casuale
JWT_SECRET=metti_uno_jwt_secret_casuale

# Origine consentita (frontend cliente staging)
CLIENT_ORIGIN=https://ecodrin-cliente-staging.onrender.com

# Email (in staging le teniamo spente)
EMAIL_MODE=disabled
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
EMAIL_USER=
EMAIL_PASS=
